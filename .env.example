# ─── PRIMARY: DeepSeek via OpenModel (FREE event — no credit card needed) ─
# 1. Sign up at https://console.openmodel.ai
# 2. Create an API key
# 3. The deepseek-v4-flash model is FREE during the event
OPENMODEL_API_KEY=om-your-openmodel-api-key-here

# ─── SECONDARY: Groq (FREE — no credit card needed) ──────────────────────
# Get your key at https://console.groq.com/keys
# Falls back automatically if DeepSeek fails
GROQ_API_KEY=your-groq-api-key-here

# Model overrides (optional — defaults shown)
GROQ_MODEL_DEEP=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MODEL_QUICK=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Telegram Bot (admin forwarding) ────────────────────────────────────
# Get bot token from https://t.me/BotFather
# Get chat ID by messaging @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Server ─────────────────────────────────────────────────────────────
PORT=3000
