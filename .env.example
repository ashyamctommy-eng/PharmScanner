# ─── PRIMARY: Groq (FREE — no credit card needed) ─────────────────────────
# Get your key at https://console.groq.com/keys
# Free tier: 30 req/min, 6000 req/day, 9000 tokens/min
GROQ_API_KEY=your-groq-api-key-here

# Model overrides (optional — defaults shown)
GROQ_MODEL_DEEP=llama-3.2-90b-vision-preview   # used when tier = "deep"
GROQ_MODEL_QUICK=llama-3.2-11b-vision-preview   # used when tier = "quick"

# ─── FALLBACK: Anthropic Claude Haiku ────────────────────────────────────
# Get key at https://console.anthropic.com
# Used ONLY when Gemini returns 429/500/quota errors — invisible to users.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Claude model (optional — default shown)
CLAUDE_MODEL=claude-3-haiku-20240307

# ─── Server ─────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Override only for local dev.
PORT=3000
